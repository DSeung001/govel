---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <main class="shell">
      <header class="header">
        <h1><a href="/" style="text-decoration:none;color:inherit;">Govel</a></h1>
        <p class="muted" style="margin:6px 0 0;">Minimal GitHub-native worldbuilding MVP</p>
      </header>
      <slot />
    </main>
  </body>
</html>
